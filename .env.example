# DreamCatcher environment — copy to .env and fill in.
#   copy .env.example .env   (Windows)

# Secret for signing session cookies. Generate a random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Single admin account.
ADMIN_USERNAME=admin
# bcrypt hash of the admin password. Generate with:
#   python -m app.security hash "your-password"
ADMIN_PASSWORD_HASH=

# Default language (el | en).
DEFAULT_LANG=el

# Optional overrides.
# DB_URL=sqlite:///D:/Dreamcatcher_site_with_billing/data.db
# MAX_UPLOAD_BYTES=8388608
# DEBUG=false
# Send session cookie only over HTTPS (default: on when DEBUG is off).
# SESSION_HTTPS_ONLY=true

# --- Payments: Viva.com -----------------------------------------------------
# demo = internal stub checkout (no keys needed). live = real Viva API.
VIVA_MODE=demo
# Required only when VIVA_MODE=live:
VIVA_MERCHANT_ID=
VIVA_API_KEY=
VIVA_CLIENT_ID=
VIVA_CLIENT_SECRET=
VIVA_SOURCE_CODE=
VIVA_WEBHOOK_SECRET=
# Public URL of this site (used to build Viva redirect/callback URLs in live mode).
PUBLIC_BASE_URL=http://127.0.0.1:8000

# --- Email notifications (optional; off by default) -------------------------
NOTIFY_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
